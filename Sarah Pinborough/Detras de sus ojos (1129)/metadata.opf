        <dc:title>Detrás de sus ojos</dc:title>
        <dc:creator opf:file-as="Pinborough, Sarah" opf:role="aut">Sarah Pinborough</dc:creator>
        <dc:contributor opf:file-as="calibre" opf:role="bkp">calibre (7.3.0) [https://calibre-ebook.com]</dc:contributor>
