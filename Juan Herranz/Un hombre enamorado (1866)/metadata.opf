        <dc:title>Un hombre enamorado</dc:title>
        <dc:creator opf:file-as="Herranz, Juan" opf:role="aut">Juan Herranz</dc:creator>
        <dc:contributor opf:file-as="calibre" opf:role="bkp">calibre (7.17.0) [https://calibre-ebook.com]</dc:contributor>
        <dc:date>2024-08-27T03:00:00+00:00</dc:date>
        <dc:description>&lt;div&gt;Pero ahora está enamorado y puede ser aún más peligroso e imprevisible.&lt;br&gt;Él es un asesino minucioso, porque así se sabe inalcanzable.&lt;br&gt;Y se emplea más a fondo para defender lo que ha aprendido a amar.&lt;br&gt;Aunque..., si sus asesinatos perfectos no dejan huella, quizás si deje rastro su amor.&lt;/div&gt;</dc:description>
