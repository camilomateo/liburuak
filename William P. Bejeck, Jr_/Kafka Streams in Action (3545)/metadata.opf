        <dc:title>Kafka Streams in Action</dc:title>
        <dc:creator opf:file-as="William P. Bejeck, Jr. &amp; Bejeck, William P. &amp; Jr." opf:role="aut">William P. Bejeck, Jr.</dc:creator>
